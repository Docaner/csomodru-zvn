	*/
	
	
	Monster_Spawn(vecOrigin);
}












Monster_Spawn(/*const*/ Float: vecOrigin[3] = {413.0, -643.0, -127.0} /*= {642.0, -1057.0, -1631.0}*/)
{
	new iMonster;

	static iszAllocStringCached;
	if (iszAllocStringCached || (iszAllocStringCached = engfunc(EngFunc_AllocString, MONSTER_REFERANCE)))
	{
		iMonster = engfunc(EngFunc_CreateNamedEntity, iszAllocStringCached);
	}
	
	if (!IsValidPev(iMonster))
	{
		return FM_NULLENT;
	}
	
	set_pev(iMonster, pev_flags, FL_MONSTER); 
	set_pev(iMonster, pev_impulse, g_iszMonsterKey);
	
	set_pev_string(iMonster, pev_classname, g_iszMonsterKey);
	
	engfunc(EngFunc_SetModel, iMonster, MONSTER_MODEL); 
	engfunc(EngFunc_SetSize, iMonster, Float:{-24.0, -24.0, -36.0}, Float:{24.0, 24.0, 160.0}); 
	
	set_pev(iMonster, pev_solid, SOLID_SLIDEBOX); 
	set_pev(iMonster, pev_movetype, MOVETYPE_STEP); 
	////////////////
	set_pdata_int(iMonster, m_bloodColor, MONSTER_BLOODCOLOR, XO_CBaseMonster);
	////////////////
	set_pev(iMonster, pev_health, MONSTER_HEALTH);
	set_pev(iMonster, pev_max_health, MONSTER_HEALTH);
	
	//m_flFieldOfView		= -0.2;// width of forward view cone ( as a dotproduct result )
	//m_flDistTooFar		= 1024.0;
	//m_flDistLook		= 2048.0;
	
	set_pev(iMonster, pev_takedamage, DAMAGE_YES);
	
	//m_IdealActivity = ACT_IDLE;
	//SetActivity( ACT_IDLE );
	//Monster_SetState(iMonster, MONSTERSTATE_IDLE);
	
	//ClearSchedule();
	//RouteClear();
	//InitBoneControllers( ); // FIX: should be done in Spawn
	
	vecOrigin[2] += 1.0; 
	
	engfunc(EngFunc_SetOrigin, iMonster, vecOrigin); 
	engfunc(EngFunc_DropToFloor, iMonster);
	
	Animation_SetAnim(iMonster, sequence_idle);
	
	if (!engfunc(EngFunc_WalkMove, iMonster, 0.0, 0.0, WALKMOVE_NORMAL))
	{
		server_print("Monster stuck in wall!");
	}

	set_pev(iMonster, pev_nextthink, get_gametime() + 0.1);
	
	
	
	//HpBar_Create(iMonster);
	
	return iMonster;
}

public Monster_Classify(const iMonster)
{
	#define CLASS_ALIEN_MONSTER 7
	
	if (IsValidPev(iMonster) && IsMonster(iMonster))
	{
		SetHamReturnInteger(CLASS_ALIEN_MONSTER);
		return HAM_OVERRIDE;	
	}
	
	return HAM_IGNORED;
}

public Monster_Killed(const iMonster, const iKiller, const iShouldGib)
{
	if (!IsValidPev(iMonster) || !IsMonster(iMonster))
	{
		return HAM_IGNORED;
	}
	
	// Already dying?
	if (pev(iMonster, pev_deadflag) >= DEAD_DYING)
	{
		return HAM_SUPERCEDE;
	}
	
	// Time to die :(
	set_pev(iMonster, pev_deadflag, DEAD_DYING);
	
	// Never gib such huge monster.
	SetHamParamInteger(3, 1);
	
	// Time to remove hpbar.
	HpBar_Destroy(iMonster);
	
	// Remove monster flag to avoid some problems.
	set_pev(iMonster, pev_flags, pev(iMonster, pev_flags) & ~FL_MONSTER);
	
	// Fade monster corpse later.
	entity_set_float(iMonster, EV_FL_flFadeTime, get_gametime() + 4.06);
	
	// Set death activity.
	Animation_SetAnim(iMonster, sequence_death);
	
	return HAM_SUPERCEDE;
}

public Monster_Think(const iMonster)
{
	if (!IsValidPev(iMonster) || !IsMonster(iMonster))
	{
		return HAM_IGNORED;
	}

	// Keep monster thinking.
	set_pev(iMonster, pev_nextthink, get_gametime() + 0.1);
	
	// Animate.
	new Float: flInterval = Animation_StudioFrameAdvance(iMonster);
	
	// Take care about animation events.
	Animation_DispatchAnimEvents(iMonster, flInterval);

	// Still alive!
	if (!IS_ALIVE(iMonster))
	{
		// Monster is dead :(
		// Lets fade out corpses from map. RIP.
		Monster_FadeOut(iMonster);
		
	}
	else
	{
		// Check and update hp bar for monster.
		HpBar_UpdateEffect(iMonster);
		
		// Find best enemy to attack.
		Monster_GetEnemy(iMonster);
		
		if (pev(iMonster, pev_enemy))
		{
			// Try to reach and attack enemy
			Monster_Move(iMonster, flInterval);
			
		}
		else if (get_pdata_float(iMonster, m_flNextAttack, XO_CBaseMonster) < get_gametime())
		{
			// Monster don't have enemy, just idle
			Animation_SetAnim(iMonster, sequence_idle);
		}
	}
	

	return HAM_SUPERCEDE;
}

Monster_FadeOut(const iMonster)
{
	new Float: flFadeTime = entity_get_float(iMonster, EV_FL_flFadeTime);
		
	if (flFadeTime == -1.0)
	{
		if (entity_get_float(iMonster, EV_FL_renderamt) > 1.0)
		{
			set_pev(iMonster, pev_renderamt, entity_get_float(iMonster, EV_FL_renderamt) - 1.0);
		}
		else 
		{
			set_pev(iMonster, pev_renderamt, 0.0);
			set_pev(iMonster, pev_flags, pev(iMonster, pev_flags) | FL_KILLME);
		}
	}
	else if (flFadeTime <= get_gametime())
	{
		if (pev(iMonster, pev_rendermode) == kRenderNormal)
		{
			set_pev(iMonster, pev_renderamt, 255.0);
			set_pev(iMonster, pev_rendermode, kRenderTransTexture);
		}
		
		set_pev(iMonster, pev_solid, SOLID_NOT);
		set_pev(iMonster, pev_movetype, MOVETYPE_NONE);
		set_pev(iMonster, pev_effects, pev(iMonster, pev_effects) | EF_NOINTERP);
			
		entity_set_float(iMonster, EV_FL_flFadeTime, -1.0);
	}
}



Monster_CheckAttacks(const iMonster, const iEnemy, const Float: flDot, const Float: flDist)
{
	if (get_pdata_float(iMonster, m_flNextAttack, XO_CBaseMonster) >= get_gametime())
	{
		return;
	}
	
	if (flDot >= 0.7 && flDist <= 90.0)
	{
		Animation_SetAnim(iMonster, sequence_swing, 1.0, true);
		
		//ExecuteHam(Ham_TakeDamage, iEnemy, iMonster,iMonster, 150.0, DMG_SLASH | DMG_ALWAYSGIB);
		
		set_pdata_float(iMonster, m_flNextAttack, get_gametime() + 2.03 , XO_CBaseMonster);
	}
	
	//server_print("!!!! %f %f", entity_get_float(iMonster, EV_FL_fuser4), get_gametime());
}


