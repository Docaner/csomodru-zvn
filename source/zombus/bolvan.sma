#define PHOBOS_AE_SHAKE			1
#define PHOBOS_AE_SWING			2
#define PHOBOS_AE_JUMP_START		3
#define PHOBOS_AE_JUMP_END		4

Monster_HandleAnimEvent(const iMonster, const iEvent, const szEventsOptions[])
{
	#pragma unused szEventsOptions
	
	switch (iEvent)
	{
		case PHOBOS_AE_SHAKE:
		{
			UTIL_ScreenShake(iMonster, 4.0, 3.0, 1.0, 512.0);
		}
		
		case PHOBOS_AE_SWING:
		{
			new iVictim = CheckTraceHullAttack(iMonster, 110.0, 90.0, DMG_SLASH);
			
			if (iVictim && IS_MONSTER(iVictim))
			{
				new Float: vecRight[3];
				new Float: vecVelocity[3];
					
				global_get(glb_v_right, vecRight);
				pev(iVictim, pev_velocity, vecVelocity);
					
				xs_vec_mul_scalar(vecRight, 500.0, vecRight);
				xs_vec_sub(vecVelocity, vecRight, vecVelocity);
					
				set_pev(iVictim, pev_velocity, vecVelocity);
				set_pev(iVictim, pev_punchangle, {-30.0, -30.0, 30.0});
			}
		}

		default: server_print("Unhandled animation event %d for %s", iEvent, MONSTER_CLASSNAME);
	}
}


		






//*******************************************************
//*                                                     *
//* HP Bar.                                             *
//*                                                     *
//*******************************************************

HpBar_Create(const iMonster)
{
	new iBar;
	
	static iszAllocStringCached;
	if (iszAllocStringCached || (iszAllocStringCached = engfunc(EngFunc_AllocString, "env_sprite")))
	{
		iBar = engfunc(EngFunc_CreateNamedEntity, iszAllocStringCached);
	}
	
	if (!IsValidPev(iBar))
	{
		return FM_NULLENT;
	}
	
	static iszSpriteName;
	if (iszSpriteName || (iszSpriteName = engfunc(EngFunc_AllocString, HPBAR_SPRITENAME)))
	{
		set_pev_string(iBar, pev_model, iszSpriteName);
		ExecuteHam(Ham_Spawn, iBar);
	}
	
	set_pev(iBar, pev_skin, iMonster);
	set_pev(iBar, pev_aiment, iMonster);
	
	set_pev(iBar, pev_scale, HPBAR_SCALE);
	set_pev(iBar, pev_body, HPBAR_ATTACHMENT);
	set_pev(iBar, pev_movetype, MOVETYPE_FOLLOW);
	
	// Bar owned by monster, monster owned by bar, lol.
	set_pev(iBar, pev_owner, iMonster);
	set_pev(iMonster, pev_owner, iBar);
	
	return iBar;
}

HpBar_UpdateEffect(const iMonster)
{
	static iBar;
	
	if (!IsValidPev((iBar = pev(iMonster, pev_owner))))
	{
		HpBar_Create(iMonster);
	}
	else
	{
		// Calculate frame value and update hp bar.
		set_pev(iBar, pev_frame, ceil(100.0 * (entity_get_float(iMonster, EV_FL_health) / entity_get_float(iMonster, EV_FL_max_health))));
	}
}

HpBar_Destroy(iMonster)
{
	new iBar = pev(iMonster, pev_owner);
	
	if (IsValidPev(iBar))
	{
		set_pev(iBar, pev_flags, FL_KILLME);
		set_pev(iMonster, pev_owner, FM_NULLENT);
	}
}

//*******************************************************
//*                                                     *
//* Animation stuff.                                    *
//*                                                     *
//*******************************************************

#define SCRIPT_EVENT_SOUND		1004	// Play named wave file (on CHAN_BODY).
#define SCRIPT_EVENT_SOUND_VOICE	1008	// Play named wave file (on CHAN_VOICE).

#define MONSTER_EVENT_BODYDROP_LIGHT	2001
#define MONSTER_EVENT_BODYDROP_HEAVY	2002

#define SCRIPT_EVENT_SOUND_CLIENT	5004	// Play named wave file on client-side (on CHAN_BODY).

enum
{
	mstudioseqdesc_label[32],	// Sequence label.
	mstudioseqdesc_numframes,	// Number of frames per sequence.
	Array: mstudioseqdesc_events,	// Handle to array with events.
	
	mstudioseqdesc
};

enum
{
	mstudioevent_frame,
	mstudioevent_event,
	mstudioevent_options[64],
	
	mstudioevent,
};

new g_Animations[sequences_num][mstudioseqdesc];

Float: Animation_StudioFrameAdvance(const iEntity,  Float: flInterval = 0.0)
{
	static iFrame;
	
	static Float: flTime;
	static Float: flAnimtime;

	flTime = get_gametime();
	flAnimtime = entity_get_float(iEntity, EV_FL_animtime);
	
	if (flInterval == 0.0)
	{
		flInterval = flTime - flAnimtime;
		
		if (flInterval < 0.0)
		{
			set_pev(iEntity, pev_animtime, flTime);
			return 0.0;
		}
	}
	
	if (!flAnimtime)
	{
		flInterval = 0.0;
	}
	
	iFrame = floatround(entity_get_float(iEntity, EV_FL_frame) + flInterval * get_pdata_float(iEntity, m_flFrameRate, XO_CBaseAnimating) * entity_get_float(iEntity, EV_FL_framerate));
	
	if (iFrame < 0 || iFrame >= 256) 
	{
		if (get_pdata_int(iEntity, m_fSequenceLoops, XO_CBaseAnimating))
		{
			iFrame -= (iFrame / 256) * 256;
		}
		else
		{
			iFrame = (iFrame < 0) ? 0 : 255;
		}
	}
	
	if (!get_pdata_int(iEntity, m_fSequenceLoops, XO_CBaseAnimating) && iFrame == 255)
	{
		// WTF?
		flTime -= 0.05;
	}
	
	set_pev(iEntity, pev_frame, float(iFrame));
	set_pev(iEntity, pev_animtime, flTime);

	return flInterval;
}

Animation_DispatchAnimEvents(const iEntity, const Float: flInterval = 0.1)
{
	static Float: flFrame;
	static Float: flAnimtime;
	static Float: flFrameRate;
	
	static iEnd, iStart, iSequence;
	
	if ((iSequence = pev(iEntity, pev_sequence)) < 0 || iSequence >= sequences_num)
	{
		return;
	}
	
	if (g_Animations[iSequence][mstudioseqdesc_events] == Invalid_Array)
	{
		return;
	}

	flFrame = entity_get_float(iEntity, EV_FL_frame);
	flAnimtime = entity_get_float(iEntity, EV_FL_animtime);
	flFrameRate = get_pdata_float(iEntity, m_flFrameRate, XO_CBaseAnimating) * entity_get_float(iEntity, EV_FL_framerate);
	
	iEnd = floatround(flFrame + flInterval * flFrameRate);
	iStart = floatround(flFrame + (get_pdata_float(iEntity, m_flLastEventCheck, XO_CBaseAnimating) - flAnimtime) * flFrameRate);
	
	if (0 <= iEnd <= 256)
	{
		set_pdata_int(iEntity, m_fSequenceFinished, 0, XO_CBaseAnimating);
	}
	else
	{
		set_pdata_int(iEntity, m_fSequenceFinished, 1, XO_CBaseAnimating);
	}
	
	set_pdata_float(iEntity, m_flLastEventCheck, flAnimtime + flInterval, XO_CBaseAnimating);
	
	if (g_Animations[iSequence][mstudioseqdesc_numframes] <= 1)
	{
		iStart = 0;
		iEnd = 1;
	}
	else
	{
		iStart = (iStart * (g_Animations[iSequence][mstudioseqdesc_numframes] - 1)) / 256;
		iEnd = (iEnd * (g_Animations[iSequence][mstudioseqdesc_numframes] - 1)) / 256;
	}
	
	static iEvent, iArraySize, EventDesc[mstudioevent];
	
	for (iEvent = 0, iArraySize = ArraySize(g_Animations[iSequence][mstudioseqdesc_events]); iEvent < iArraySize ; iEvent++)
	{
		ArrayGetArray(g_Animations[iSequence][mstudioseqdesc_events], iEvent, EventDesc);
		
		if (iStart <= EventDesc[mstudioevent_frame] < iEnd)
		{
			Animation_HandleAnimEvent(iEntity, EventDesc[mstudioevent_event], EventDesc[mstudioevent_options]);
		}
	}
}

Animation_HandleAnimEvent(const iMonster, const iEvent, const szEventsOptions[])
{
	switch (iEvent)
	{
		case SCRIPT_EVENT_SOUND:
		{
			emit_sound(iMonster, CHAN_BODY, szEventsOptions, 1.0, ATTN_NORM, 0, PITCH_NORM);
		}
		
		case SCRIPT_EVENT_SOUND_VOICE:
		{
			emit_sound(iMonster, CHAN_VOICE, szEventsOptions, 1.0, ATTN_IDLE, 0, PITCH_NORM);
		}
		/*
		case MONSTER_EVENT_BODYDROP_LIGHT:
		{
			if (pev(iMonster, pev_flags) & FL_ONGROUND)
			{
				emit_sound(iMonster, CHAN_BODY, random_num(0, 1) ? "common/bodydrop3.wav" : "common/bodydrop4.wav", 1.0, ATTN_IDLE, 0, PITCH_NORM);
			}
		}
		
		case MONSTER_EVENT_BODYDROP_HEAVY:
		{
			if (pev(iMonster, pev_flags) & FL_ONGROUND)
			{
				emit_sound(iMonster, CHAN_BODY, random_num(0, 1) ? "common/bodydrop3.wav" : "common/bodydrop4.wav", 1.0, ATTN_IDLE, 0, 90);
			}
		}
		*/
		default: Monster_HandleAnimEvent(iMonster, iEvent, szEventsOptions);
	}
}

Animation_SetAnim(const iMonster, const iSequence, const Float: flFramerateEnt = 1.0, bool: bForce = false)
{
	if (!bForce && pev(iMonster, pev_sequence) == iSequence)
	{
		return;
	}

	new bool: bLoops;
	
	new Float: flGameTime;
	new Float: flFramerate;
	new Float: flGroundSpeed;
	
	set_pev(iMonster, pev_frame, 0.0);
	set_pev(iMonster, pev_sequence, iSequence);
	set_pev(iMonster, pev_framerate, flFramerateEnt);
	set_pev(iMonster, pev_animtime, (flGameTime = get_gametime()));
	
	lookup_sequence(iMonster, g_Animations[iSequence][mstudioseqdesc_label], flFramerate, bLoops, flGroundSpeed);
	
	set_pdata_int(iMonster, m_fSequenceFinished, 0, XO_CBaseAnimating);
	set_pdata_int(iMonster, m_fSequenceLoops, bLoops, XO_CBaseAnimating);
	
	set_pdata_float(iMonster, m_flFrameRate, flFramerate, XO_CBaseAnimating);
	set_pdata_float(iMonster, m_flGroundSpeed, flGroundSpeed, XO_CBaseAnimating);
	set_pdata_float(iMonster, m_flLastEventCheck, flGameTime, XO_CBaseAnimating);
}

Animation_ParseSequences(const szModelPath[])
{
	new iFile = fopen(szModelPath, "rt");
	
	if (!iFile)
	{
		fclose(iFile);
		set_fail_state("Failed to parse monster model!");
	}
	
	new iNumSeq;
	new iSeqIndex;
	new iNumEvents;
	new iEventIndex;
		
	new EventDesc[mstudioevent];
		
	fseek(iFile, 164, SEEK_SET);
	fread(iFile, iNumSeq, BLOCK_INT);
	fread(iFile, iSeqIndex, BLOCK_INT);
	
	if (iNumSeq != sequences_num)
	{
		fclose(iFile);
		set_fail_state("Failed to parse monster model!");
	}
		
	for (new k, i = 0; i < iNumSeq; i++)
	{
		fseek(iFile, iSeqIndex  + 176 * i, SEEK_SET);
			
		fread_blocks(iFile, g_Animations[i][mstudioseqdesc_label], 32, BLOCK_CHAR);
			
		fseek(iFile, 16, SEEK_CUR);
		fread(iFile, iNumEvents, BLOCK_INT);
		fread(iFile, iEventIndex, BLOCK_INT);
		fread(iFile, g_Animations[i][mstudioseqdesc_numframes], BLOCK_INT);
		fseek(iFile, iEventIndex + 172 * i, SEEK_SET);
			
		for (k = 0; k < iNumEvents; k++)
		{
			if (g_Animations[i][mstudioseqdesc_events] == Invalid_Array)
			{
				g_Animations[i][mstudioseqdesc_events] = _:ArrayCreate(mstudioevent, 1);
			}
				
			fseek(iFile, iEventIndex + 76 * k, SEEK_SET);
			fread(iFile, EventDesc[mstudioevent_frame], BLOCK_INT);
			fread(iFile, EventDesc[mstudioevent_event], BLOCK_INT);
			fseek(iFile, 4, SEEK_CUR);
				
			fread_blocks(iFile, EventDesc[mstudioevent_options], 64, BLOCK_CHAR);
				
			if (EventDesc[mstudioevent_event] == SCRIPT_EVENT_SOUND
				|| EventDesc[mstudioevent_event] == SCRIPT_EVENT_SOUND_VOICE
				|| EventDesc[mstudioevent_event] == SCRIPT_EVENT_SOUND_CLIENT)
			{
				engfunc(EngFunc_PrecacheSound, EventDesc[mstudioevent_options]);
		}
				
			ArrayPushArray(g_Animations[i][mstudioseqdesc_events], EventDesc);
		}
	}
	
	fclose(iFile);
	
	/*
	for (new EventDesc[mstudioevent], k, i = 0; i < sequences_num; i++)
	{
		server_print("Sequance #%d:", i);
		server_print("  Label: \"%s\", frames: %d", g_Animations[i][mstudioseqdesc_label], g_Animations[i][mstudioseqdesc_numframes]);
		
		if (g_Animations[i][mstudioseqdesc_events])
		{
			for (k = 0; k < ArraySize(g_Animations[i][mstudioseqdesc_events]); k++)
			{
				ArrayGetArray(g_Animations[i][mstudioseqdesc_events], k, EventDesc);
				
				server_print("   Event #%d: %d, frame: %d, options: \"%s\"", k, EventDesc[mstudioevent_event], EventDesc[mstudioevent_frame], EventDesc[mstudioevent_options]);
			}
		}
		
		server_print("");
	}
	*/
}

//*******************************************************
//*                                                     *
//* Utils.                                              *
//*                                                     *
//*******************************************************

CheckTraceHullAttack(const iMonster, const Float: flDist, const Float: flDamage, const iDmgType)
{
	new iHit;
	
	new Float: vecUp[3];
	new Float: vecForward[3];
	
	new Float: vecAngles[3];
	new Float: vecOrigin[3];
	
	pev(iMonster, pev_angles, vecAngles);
	pev(iMonster, pev_origin, vecOrigin);
	
	vecOrigin[2] += 24.0;
	
	engfunc(EngFunc_MakeVectors, vecAngles);
	global_get(glb_v_forward, vecForward);
	global_get(glb_v_up, vecUp);
	
	xs_vec_mul_scalar(vecForward, flDist, vecForward);
	xs_vec_mul_scalar(vecUp, flDist * 0.3, vecUp);
	
	xs_vec_sub(vecForward, vecUp, vecForward);
	xs_vec_add(vecForward, vecOrigin, vecForward);
	
	engfunc(EngFunc_TraceHull, vecOrigin, vecForward, DONT_IGNORE_MONSTERS, HULL_HEAD, iMonster, 0);
	
	if (IsValidPev(iHit = get_tr2(0, TR_pHit)))
	{	
		if (flDamage > 0.0)
		{
			ExecuteHamB(Ham_TakeDamage, iHit, iMonster, iMonster, flDamage, iDmgType);
			get_tr2(0, TR_vecEndPos, vecOrigin);
			
			UTIL_BloodDrips(vecOrigin, ExecuteHamB(Ham_BloodColor, iHit), flDamage);
		}
		
		return iHit;
	}

	return 0;
}

stock Float: UTIL_AngleMod(Float: a)
{
	if (a < 0.0)
	{
		a = a + 360.0 * ((a / 360.0) + 1.0);
	}
	else if (a >= 360.0)
	{
		a = a - 360.0 * ((a / 360.0));
	}
	
	return a;
}

stock UTIL_BloodDrips(const Float: vecSpot[3], const iBloodColor, Float: flAmount)
{
	if (iBloodColor == -1 || flAmount <= 0.0)
	{
		return;
	}
	
	flAmount *= 2;
	
	if (flAmount > 255.0)
	{
		flAmount = 255.0;
	}
	
	static iBloodIndex;
	static iBloodSprayIndex;
	
	if (!iBloodIndex)
	{
		iBloodIndex = MODEL_INDEX("sprites/blood.spr");
	}
	
	if (!iBloodSprayIndex)
	{
		iBloodSprayIndex = MODEL_INDEX("sprites/bloodspray.spr");
	}

	MESSAGE_BEGIN(MSG_PVS, SVC_TEMPENTITY, vecSpot, 0);
	WRITE_BYTE(TE_BLOODSPRITE);
	WRITE_COORD(vecSpot[0]);
	WRITE_COORD(vecSpot[1]);
	WRITE_COORD(vecSpot[2]);
	WRITE_SHORT(iBloodSprayIndex);
	WRITE_SHORT(iBloodIndex);
	WRITE_BYTE(iBloodColor);
	WRITE_BYTE(min(max(3, floatround(flAmount) / 10), 16));
	MESSAGE_END();
}

stock UTIL_ScreenShake(const iEntity, const Float: flAmplitude, const Float: flFrequency, const Float: flDuration, const Float: flRadius)
{
	for (new Float: flLocalAmplitude, iPlayer = 1, k = get_maxplayers(); iPlayer <= k; iPlayer++ )
	{
		if (!is_user_connected(iPlayer) || ~pev(iPlayer, pev_flags) & FL_ONGROUND)
		{
			continue;
		}

		flLocalAmplitude = 0.0;

		if (flRadius <= 0.0 || entity_range(iEntity, iPlayer) < flRadius)
		{
			flLocalAmplitude = flAmplitude;
		}
		
		if (flLocalAmplitude)
		{
			static msgScreenShake;
			if (msgScreenShake || (msgScreenShake = get_user_msgid("ScreenShake")))
			{
				MESSAGE_BEGIN(MSG_ONE_UNRELIABLE, msgScreenShake, {0.0, 0.0, 0.0}, iPlayer);
				WRITE_SHORT(FixedUnsigned16(flAmplitude, 1<<12));
				WRITE_SHORT(FixedUnsigned16(flDuration, 1<<12));
				WRITE_SHORT(FixedUnsigned16(flFrequency, 1<<8));
				MESSAGE_END();
			}
		}
	}
}

// Thanks to ConnorMcLeod.
// We both hate float(floatround()) way :D
stock Float: ceil(const Float: x)
{
	new sign = _:x >> 31;
	new exponent = ((_:x & 0x7FFFFFFF) >> 23) - 127;
	new mantissa = _:x & 0x7FFFFF;

	if (exponent < 0) 
	{   
		if (x <= 0.0)
		{
			return 0.0;
		}
		else
		{
			return 1.0;
		}
	}
	else
	{
		new mask = 0x7fffff >> exponent;

		if ((mantissa & mask) == 0)
		{
			return x;
		}
		else
		{
			if (!sign)
			{
				mantissa += 1 << (23 - exponent);

				if (mantissa & 0x800000)
				{
					mantissa = 0;
					exponent++;
				}
			}

			mantissa &= ~mask;
		}
	}

	return Float: ((sign << 31) | ((exponent + 127) << 23) | mantissa);
}

stock FixedUnsigned16(const Float: flValue, const iScale)
{
	new iOutput = floatround(flValue * iScale);
	
	if (iOutput < 0)
	{
		iOutput = 0;
	}
	
	if (iOutput > 0xFFFF)
	{
		iOutput = 0xFFFF;
	}

	return iOutput;
}
