public plugin_precache()
{
	#if defined _HLDM_
	
		if (!is_running("valve"))
		{
			set_fail_state("Plugin");
		}
		
	#endif
	
	
	
	register_plugin(PLUGIN, VERSION, AUTHOR);
	
	register_clcmd("say /Bolvan", "ClCmd_Create"); 
	
	RegisterHam(Ham_Think, MONSTER_REFERANCE, "Monster_Think");
	RegisterHam(Ham_Classify, MONSTER_REFERANCE, "Monster_Classify");
	RegisterHam(Ham_Killed, MONSTER_REFERANCE, "Monster_Killed");
	


	g_iszMonsterKey = engfunc(EngFunc_AllocString, MONSTER_CLASSNAME);
	
	precache_model(MONSTER_MODEL);
	Animation_ParseSequences(MONSTER_MODEL);
	
	
	precache_model(HPBAR_SPRITENAME);
	
	

	
	
	
	
	//RegisterHam(Ham_TraceAttack, MONSTER_REFERANCE, "Monster_TakeDamage");
}
