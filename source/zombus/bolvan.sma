public ClCmd_Create(const iPlayer)
{
	new Float: vecOrigin[3];
	pev(iPlayer, pev_origin, vecOrigin);
	
	
	//server_print("!!!!!!!! %f %f %f", vecOrigin[0], vecOrigin[1], vecOrigin[2]);
	
	
	
	
