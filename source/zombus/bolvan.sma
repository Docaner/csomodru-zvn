//=========================================================
// BolvanAI
//=========================================================

#define	LOCALMOVE_INVALID			0 // move is not possible
#define LOCALMOVE_INVALID_DONT_TRIANGULATE	1 // move is not possible, don't try to triangulate
#define LOCALMOVE_VALID				2 // move is possible

Monster_FindBestEnemy(const iMonster, const Float: flDistance, bool: bInViewCone = false)
{
	new iEnemy;
	new iEntity;
	
	new Float: flDist;
	new Float: flNearest = 8192.0;
	
	new Float: vecSrc[3];
	pev(iMonster, pev_origin, vecSrc);
	
	while ((iEntity = find_ent_in_sphere(iEntity, vecSrc, flDistance)))
	{
		if (iEntity != iMonster && IS_MONSTER(iEntity) && IS_ALIVE(iEntity) && entity_get_float(iEntity, EV_FL_takedamage) != DAMAGE_NO && is_visible(iEntity, iMonster))
		{
			if ((flDist = entity_range(iMonster, iEntity)) < flNearest)
			{
				iEnemy = iEntity;
				flNearest = flDist;
			}
		}
	}
	
	return iEnemy;
}

Monster_GetEnemy(const iMonster)
{
	static iEnemy;
	static bool: bFindTarget;

	bFindTarget = false;
	
	if (!(iEnemy = pev(iMonster, pev_enemy)) && !(iEnemy = Monster_FindBestEnemy(iMonster, 2048.0)))
	{
		set_pev(iMonster, pev_enemy, 0);
		return;
	}
	
	Monster_CheckEnemy(iMonster, iEnemy);

	if (!IS_ALIVE(iEnemy))
	{
		//iEnemy = Monster_FindBestEnemy(iMonster, 2048.0);
	}
	else if (entity_range(iMonster, iEnemy) > 768.0)
	{
		bFindTarget = true;
	}
	//else
	{
		// Track the target.

		new Float: flCheckDist;
		
		static Float: vecOrigin[3];
		static Float: vecLocation[3];
		static Float: vecDirToPoint[3];
		
		flCheckDist = entity_range(iMonster, iEnemy);
		
		pev(iMonster, pev_origin, vecOrigin);
		pev(iEnemy, pev_origin, vecLocation);
		
		xs_vec_sub(vecLocation, vecOrigin, vecDirToPoint);
		xs_vec_normalize(vecDirToPoint, vecDirToPoint);
		xs_vec_mul_scalar(vecDirToPoint, flCheckDist, vecDirToPoint);
		xs_vec_add(vecOrigin, vecDirToPoint, vecDirToPoint);
		
		if (Monster_CheckLocalMove(iMonster, vecOrigin, vecDirToPoint, iEnemy, flCheckDist) == LOCALMOVE_VALID)
		{
			server_print("NORMAL");
			set_pev(iMonster, pev_vuser1, vecLocation);
		}
		else
		{
			static Float: vecApex[3];
			
			
			server_print("!!!!! %f", flCheckDist);
			
			if (FTriangulate(iMonster, vecOrigin, vecLocation, flCheckDist, iEnemy, vecApex))
			{
				//server_print("!!!!! NO %f", get_gametime());
				
				
				set_pev(iMonster, pev_vuser1, vecApex);
				
				server_print("FIND A WAY");
			}
			else
			{
				bFindTarget = true;
				
				server_print("CANT REACH");
				
				//set_pev(iMonster, pev_vuser1, vecLocation);
			}
		}
		
	}
	
	if (bFindTarget)
	{
		new iNewEnemy = Monster_FindBestEnemy(iMonster, 2048.0);
		
		if (iNewEnemy && iNewEnemy != iEnemy)
		{
			iEnemy = iNewEnemy;
		}
	}
	
	set_pev(iMonster, pev_enemy, iEnemy);
}






Monster_CheckLocalMove(const iMonster, const Float: vecStart[3], const Float: vecEnd[3], const iTarget, &Float: pflDist = -1.0)
{
	new iReturn = LOCALMOVE_VALID;
	
	new Float: flYaw;
	new Float: flDist;
	new Float: flStep;
	new Float: stepSize;
	
	new Float: vecPoint[3];
	new Float: vecStartPos[3];
	
	pev(iMonster, pev_origin, vecStartPos);
	xs_vec_sub(vecEnd, vecStart, vecPoint);
	
	engfunc(EngFunc_VecToYaw, vecPoint, flYaw);
	engfunc(EngFunc_SetOrigin, iMonster, vecStart); 
	engfunc(EngFunc_DropToFloor, iMonster);
	
	flDist = xs_vec_len(vecPoint);

	// this loop takes single steps to the goal.
	for (flStep = 0.0; flStep < flDist; flStep += 16.0)
	{
		stepSize = 16.0;

		if ((flStep + 16.0) >= (flDist - 1.0))
		{
			stepSize = (flDist - flStep) - 1.0;
		}
		
		if (!engfunc(EngFunc_WalkMove, iMonster, flYaw, stepSize, 2))
		{
			// can't take the next step, fail!
			if (pflDist != -1.0)
			{
				pflDist = flStep;
			}

			if (iTarget && iTarget == get_global_edict(GL_trace_ent))
			{
				// if this step hits target ent, the move is legal.
				iReturn = LOCALMOVE_VALID;
				break;
			}
			else
			{
				// If we're going toward an entity, and we're almost getting there, it's OK.
//				if ( pTarget && fabs( flDist - iStep ) < LOCAL_STEP_SIZE )
//					fReturn = TRUE;
//				else
				iReturn = LOCALMOVE_INVALID;
				break;
			}

		}
	}
/*
	if (iReturn == LOCALMOVE_VALID && !(pev->flags & (FL_FLY|FL_SWIM) ) && (!pTarget || (pTarget->pev->flags & FL_ONGROUND)) )
	{
		// The monster can move to a spot UNDER the target, but not to it. Don't try to triangulate, go directly to the node graph.
		// UNDONE: Magic # 64 -- this used to be pev->size.z but that won't work for small creatures like the headcrab
		if ( fabs(vecEnd.z - pev->origin.z) > 64 )
		{
			iReturn = LOCALMOVE_INVALID_DONT_TRIANGULATE;
		}
	}*/
	/*
	// uncommenting this block will draw a line representing the nearest legal move.
	WRITE_BYTE(MSG_BROADCAST, SVC_TEMPENTITY);
	WRITE_BYTE(MSG_BROADCAST, TE_SHOWLINE);
	WRITE_COORD(MSG_BROADCAST, pev->origin.x);
	WRITE_COORD(MSG_BROADCAST, pev->origin.y);
	WRITE_COORD(MSG_BROADCAST, pev->origin.z);
	WRITE_COORD(MSG_BROADCAST, vecStart.x);
	WRITE_COORD(MSG_BROADCAST, vecStart.y);
	WRITE_COORD(MSG_BROADCAST, vecStart.z);
	*/
	
	if (iReturn == LOCALMOVE_VALID && (!iTarget || (pev(iTarget, pev_flags) & FL_ONGROUND)))
	{
		new Float: vecOrigin[3];
		pev(iMonster, pev_origin, vecOrigin);
		
		if (floatabs(vecEnd[2] - vecOrigin[2]) > 64.0)
		{
			iReturn = LOCALMOVE_INVALID_DONT_TRIANGULATE;
		}
	}
	
	// since we've actually moved the monster during the check, undo the move.
	engfunc(EngFunc_SetOrigin, iMonster, vecStartPos); 

	return iReturn;
}

Monster_Move(const iMonster, const Float: flInterval)
{
	
	/*
	if ( m_flMoveWaitFinished > gpGlobals->time )
		return;
	*/
	new Float: vecTemp[3];
	
	new Float: vecAngles[3];
	new Float: vecOrigin[3];
	new Float: vecLocation[3];
	//new Float: vecDirToPoint[3];
	
	pev(iMonster, pev_angles, vecAngles);
	pev(iMonster, pev_origin, vecOrigin);
	pev(iMonster, pev_vuser1, vecLocation);

	


	
	
	
	/*
	xs_vec_sub(vecLocation, vecOrigin, vecDirToPoint);
	
	new Float: flCheckDist = xs_vec_len(vecDirToPoint);
	
	xs_vec_normalize(vecDirToPoint, vecDirToPoint);
	xs_vec_mul_scalar(vecDirToPoint, flCheckDist, vecDirToPoint);
	xs_vec_add(vecOrigin, vecDirToPoint, vecDirToPoint);
	*/
	

	
	

	
	/*
	new Float: vecApex[3];
	
	if (Monster_CheckLocalMove(iMonster, vecOrigin, vecDirToPoint, pev(iMonster, pev_enemy), flCheckDist) != LOCALMOVE_VALID )
	{
		// try to triangulate around whatever is in the way.
		if (!FTriangulate(iMonster, vecOrigin, vecLocation, flCheckDist, pev(iMonster, pev_enemy), vecApex))
		{
			//server_print("!!!!! NO %f", get_gametime());
			set_pev(iMonster, pev_vuser1, vecLocation);
		}
		else
		{
			set_pev(iMonster, pev_vuser1, vecApex);
		}
	}
	else
	{
		set_pev(iMonster, pev_vuser1, {0.0, 0.0, 0.0});
	}

	pev(iMonster, pev_vuser1, vecApex);
	
	if (xs_vec_len(vecApex))
	{
		xs_vec_copy(vecApex, vecLocation);
	}
	*/
	
	
	
	
	
	
	
	
	
	
	
	xs_vec_sub(vecLocation, vecOrigin, vecTemp);
	
	new Float: flIdealYaw; 
	engfunc(EngFunc_VecToYaw, vecTemp, flIdealYaw);
	new Float: flCurrentYaw = UTIL_AngleMod(vecAngles[1]);
	
	
	if (/*!Monster_FacingIdeal(iMonster) &&*/ flCurrentYaw != flIdealYaw)
	{
		new Float: flSpeed = /*(float)yawSpeed*/ 20.0/* * get_global_float(GL_frametime) * 10.0*/;
		new Float: flMove = flIdealYaw - flCurrentYaw;
		
		if (flIdealYaw > flCurrentYaw)
		{
			if (flMove >= 180.0)
			{
				flMove = flMove - 360.0;
			}
		}
		else
		{
			if (flMove <= -180.0)
			{
				flMove = flMove + 360.0;
			}
		}
		
		if (flMove > 0.0)
		{

			// turning to the monster's left
			if (flMove > flSpeed)
			{
				flMove = flSpeed;
			}
		}
		else
		{
			// turning to the monster's right
			if (flMove < -flSpeed)
			{
				flMove = -flSpeed;
			}
		}
		
		vecAngles[1] = UTIL_AngleMod(flCurrentYaw + flMove);
		set_pev(iMonster, pev_angles, vecAngles);
	}
	
	
	if (!xs_vec_len(vecLocation))
	{
		return;
	}
	
	
	if (get_pdata_float(iMonster, m_flNextAttack, XO_CBaseMonster) >= get_gametime())
	{
		return;
	}
	
	new Float: flStep, Float: flTotal = get_pdata_float(iMonster, m_flGroundSpeed, XO_CBaseAnimating) * entity_get_float(iMonster, EV_FL_framerate) * flInterval;

	while (flTotal > 0.001)
	{
		
		flStep = floatmin(16.0, flTotal);
		engfunc(EngFunc_MoveToOrigin, iMonster, vecLocation, flStep, 1);
		flTotal -= flStep;
	}

	Animation_SetAnim(iMonster, sequence_run, 2.0);
}


/*
bool: Monster_FacingIdeal(const iMonster)
{
	if (floatabs(Monster_FlYawDiff(iMonster)) <= 0.006)
	{
		return true;
	}

	return false;
}

Monster_FlYawDiff(const iMonster)
{
	new Float: vecAngles[3];
	pev(iMonster, pev_angles, vecAngles);

	if (UTIL_AngleMod( pev->angles.y ) == pev->ideal_yaw )
	{
		return 0;
	}

	return UTIL_AngleDiff( pev->ideal_yaw, flCurrentYaw );
}
*/

public FTriangulate(const iMonster, const Float: vecStart[3], const Float: vecEnd[3], const Float: flDist, const iTarget, Float: vecApex[3])
{
	new Float: vecDir[3];
	new Float: vecForward[3];
	new Float: vecLeft[3];// the spot we'll try to triangulate to on the left
	new Float: vecRight[3];// the spot we'll try to triangulate to on the right
	new Float: vecFarSide[3];// the spot that we'll move to after hitting the triangulated point, before moving on to our normal goal.

	pev(iMonster, pev_size, vecFarSide);

	new Float: sizeX = vecFarSide[0];
	
	if (sizeX < 24.0)
	{
		sizeX = 24.0;
	}
	else if (sizeX > 48.0)
	{
		sizeX = 48.0;
	}
	
	xs_vec_sub(vecEnd, vecStart, vecForward);
	xs_vec_normalize(vecForward, vecForward);
	xs_vec_cross(vecForward, Float: {0.0, 0.0, 1.0}, vecDir);

	// start checking right about where the object is, picking two equidistant starting points, one on
	// the left, one on the right. As we progress through the loop, we'll push these away from the obstacle, 
	// hoping to find a way around on either side. pev->size.x is added to the ApexDist in order to help select
	// an apex point that insures that the monster is sufficiently past the obstacle before trying to turn back
	// onto its original course.

	xs_vec_mul_scalar(vecDir, sizeX * 3.0, vecLeft);
	xs_vec_sub(vecStart, vecLeft, vecLeft);
	xs_vec_mul_scalar(vecForward, flDist + sizeX, vecFarSide);
	xs_vec_add(vecFarSide, vecLeft, vecLeft);
	
	xs_vec_mul_scalar(vecDir, sizeX * 3.0, vecRight);
	xs_vec_add(vecStart, vecRight, vecRight);
	xs_vec_mul_scalar(vecForward, flDist + sizeX, vecFarSide);
	xs_vec_add(vecFarSide, vecRight, vecRight);
	
	xs_vec_copy(vecEnd, vecFarSide);
	xs_vec_mul_scalar(vecDir, sizeX * 2.0, vecDir);

	for (new i = 0; i < 8; i++ )
	{
		if (Monster_CheckLocalMove(iMonster, vecStart, vecRight, iTarget) == LOCALMOVE_VALID)
		{
			if (Monster_CheckLocalMove(iMonster, vecRight, vecFarSide, iTarget) == LOCALMOVE_VALID)
			{
				xs_vec_copy(vecRight, vecApex);

				return 1;
			}
		}
		if (Monster_CheckLocalMove(iMonster, vecStart, vecLeft, iTarget) == LOCALMOVE_VALID)
		{
			if (Monster_CheckLocalMove(iMonster, vecLeft, vecFarSide, iTarget) == LOCALMOVE_VALID)
			{
				xs_vec_copy(vecLeft, vecApex);

				return 1;
			}
		}
		
		xs_vec_add(vecRight, vecDir, vecRight);
		xs_vec_sub(vecLeft, vecDir, vecLeft);
	}

	return 0;
}



